<style>
    body {
        background: url('/img/IGLESIA.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }

    .view-container {
        max-width: 1000px;
        margin: 30px auto;
        background: rgba(255, 255, 255, 0.95);
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.2);
        border-radius: 8px;
        overflow: hidden;
        backdrop-filter: blur(5px);
    }

    .view-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white;
        padding: 40px;
        position: relative;
    }

    .view-header h1 {
        font-weight: 700;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .view-header .subtitle {
        font-size: 1.1rem;
        opacity: 0.9;
    }

    .section-title {
        color: #0d6efd;
        font-weight: 700;
        border-bottom: 2px solid #e9ecef;
        padding-bottom: 10px;
        margin-bottom: 25px;
        margin-top: 40px;
        text-transform: uppercase;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
    }

    .info-label {
        font-size: 0.85rem;
        color: #6c757d;
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .info-value {
        font-size: 1rem;
        color: #212529;
        font-weight: 500;
        margin-bottom: 15px;
    }

    .info-value.empty {
        color: #adb5bd;
        font-style: italic;
    }

    .card-custom {
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 20px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .card-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
    }

    .timeline-item {
        position: relative;
        padding-left: 30px;
        margin-bottom: 25px;
        border-left: 2px solid #e9ecef;
    }

    .timeline-item::before {
        content: '';
        position: absolute;
        left: -6px;
        top: 0;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #0d6efd;
    }

    .timeline-date {
        font-size: 0.9rem;
        color: #6c757d;
        margin-bottom: 5px;
    }

    .timeline-title {
        font-weight: 700;
        font-size: 1.1rem;
        color: #212529;
    }

    .timeline-subtitle {
        color: #0d6efd;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .badge-custom {
        background-color: #e7f1ff;
        color: #0d6efd;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .download-link {
        text-decoration: none;
        color: #0d6efd;
        font-weight: 500;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        transition: color 0.2s;
    }

    .download-link:hover {
        color: #0a58ca;
        text-decoration: underline;
    }

    .table-custom th {
        background-color: #f8f9fa;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        color: #495057;
    }

    .fab-container {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 1000;
    }

    .profile-photo {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid rgba(255, 255, 255, 0.3);
        margin-right: 25px;
        background-color: #fff;
    }

    .header-content {
        display: flex;
        align-items: center;
    }

    @media (max-width: 768px) {
        .header-content {
            flex-direction: column;
            text-align: center;
        }

        .profile-photo {
            margin-right: 0;
            margin-bottom: 15px;
        }
    }

    @media print {
        .no-print {
            display: none !important;
        }

        .view-container {
            box-shadow: none;
            margin: 0;
            width: 100%;
            max-width: none;
        }

        body {
            background: white;
        }
    }
</style>

<div class="view-container">
    <!-- Header -->
    <div class="view-header">
        <div class="row align-items-center">
            <div class="col-md-9">
                <div class="header-content">
                    {{#if persona.foto_perfil}}
                    <img src="/docs/{{persona.foto_perfil}}" alt="Foto de Perfil" class="profile-photo">
                    {{else}}
                    <div class="profile-photo d-flex align-items-center justify-content-center text-secondary fs-1">
                        <i class="fas fa-user"></i>
                    </div>
                    {{/if}}
                    <div>
                        <h1>{{persona.nombres}} {{persona.primer_apellido}} {{persona.segundo_apellido}}</h1>
                        <div class="subtitle">
                            <i class="fas fa-id-card me-2"></i> {{persona.tipo_documento}} {{persona.numero_documento}}
                        </div>
                        <div class="mt-3">
                            <span class="me-3"><i class="fas fa-envelope me-1"></i> {{persona.email}}</span>
                            <span><i class="fas fa-phone me-1"></i> {{persona.telefono}}</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 text-md-end mt-3 mt-md-0 no-print">
                <a href="/hoja/generar-pdf/{{persona.unique_identifier}}" class="btn btn-light shadow-sm fw-bold">
                    <i class="fas fa-file-pdf me-2"></i> Descargar PDF
                </a>
            </div>
        </div>
    </div>

    <div class="p-4 p-md-5">

        <!-- 1. DATOS PERSONALES -->
        <h2 class="section-title"><i class="fas fa-user-circle me-2"></i> Datos Personales</h2>
        <div class="row g-4">
            <div class="col-md-3">
                <div class="info-label">Nacionalidad</div>
                <div class="info-value">
                    {{#if (eq persona.nacionalidad "COLOMBIANO")}}
                    Colombiano
                    {{else}}
                    {{#if (eq persona.nacionalidad "EXTRANJERO")}}
                    Extranjero {{#if persona.pais}}({{persona.pais}}){{/if}}
                    {{else}}
                    <span class="info-value empty">No especificado</span>
                    {{/if}}
                    {{/if}}
                </div>
            </div>
            <div class="col-md-3">
                <div class="info-label">Sexo</div>
                <div class="info-value">
                    {{#if (eq persona.sexo "M")}}Masculino{{/if}}
                    {{#if (eq persona.sexo "F")}}Femenino{{/if}}
                    {{#unless persona.sexo}}<span class="info-value empty">No especificado</span>{{/unless}}
                </div>
            </div>
            <div class="col-md-3">
                <div class="info-label">Fecha de Nacimiento</div>
                <div class="info-value">{{#if persona.fecha_nacimiento}}{{formatFullDate
                    persona.fecha_nacimiento}}{{else}}<span class="info-value empty">--/--/----</span>{{/if}}</div>
            </div>
            <div class="col-md-3">
                <div class="info-label">Lugar de Nacimiento</div>
                <div class="info-value">
                    {{#if persona.municipio_nacimiento}}
                    {{persona.municipio_nacimiento}}, {{persona.departamento_nacimiento}}
                    {{#if persona.pais_nacimiento}}({{persona.pais_nacimiento}}){{/if}}
                    {{else}}
                    <span class="info-value empty">No especificado</span>
                    {{/if}}
                </div>
            </div>

            <!-- Libreta Militar -->
            {{#if persona.tipo_libreta_militar}}
            <div class="col-md-3">
                <div class="info-label">Libreta Militar</div>
                <div class="info-value">{{persona.tipo_libreta_militar}}</div>
            </div>
            <div class="col-md-3">
                <div class="info-label">Número Libreta</div>
                <div class="info-value">{{persona.numero_libreta_militar}}</div>
            </div>
            <div class="col-md-3">
                <div class="info-label">Distrito Militar</div>
                <div class="info-value">{{persona.dm_libreta_militar}}</div>
            </div>
            <div class="col-md-3"></div> <!-- Spacer -->
            {{/if}}

            <!-- Dirección -->
            <div class="col-12">
                <div class="info-label">Dirección de Correspondencia</div>
                <div class="info-value">
                    {{#if persona.direccion_correspondencia}}
                    {{persona.direccion_correspondencia}}
                    <br>
                    <small class="text-muted">
                        {{persona.municipio_correspondencia}}, {{persona.departamento_correspondencia}}{{#if
                        persona.pais_correspondencia}}, {{persona.pais_correspondencia}}{{/if}}
                    </small>
                    {{else}}
                    <span class="info-value empty">No registrada</span>
                    {{/if}}
                </div>
            </div>
        </div>

        <!-- 2. FORMACIÓN ACADÉMICA -->
        <h2 class="section-title"><i class="fas fa-graduation-cap me-2"></i> Formación Académica</h2>

        <!-- Básica y Media -->
        <div class="card-custom bg-light border-0">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h5 class="fw-bold mb-1">Educación Básica y Media</h5>
                    <p class="mb-0 text-muted">{{#if
                        educacion_basica_media.titulo_obtenido}}{{educacion_basica_media.titulo_obtenido}}{{else}}Título
                        no registrado{{/if}}</p>
                </div>
                <div class="col-md-4 text-md-end mt-2 mt-md-0">
                    {{#if educacion_basica_media.educacion_basica}}
                    <span class="badge bg-secondary">Grado {{educacion_basica_media.educacion_basica}}°</span>
                    {{/if}}
                    {{#if educacion_basica_media.fecha_grado}}
                    <div class="small text-muted mt-1">Grado: {{formatDate educacion_basica_media.fecha_grado}}</div>
                    {{/if}}
                </div>
            </div>
        </div>

        <!-- Educación Superior -->
        {{#if educacion_superior.length}}
        <h5 class="mb-3 text-secondary fw-bold small">EDUCACIÓN SUPERIOR</h5>
        {{#each educacion_superior}}
        <div class="timeline-item">
            <div class="timeline-date">{{formatDate this.mes_terminacion}}</div>
            <div class="timeline-title">{{this.nombre_titulo}}</div>
            <div class="timeline-subtitle">{{this.modalidad_academica}}</div>

            <div class="row g-2 mt-1">
                <div class="col-auto">
                    <span class="badge-custom">
                        {{#if (eq this.graduado "SI")}}Graduado{{else}}En Curso{{/if}}
                    </span>
                </div>
                <div class="col-auto">
                    <span class="badge-custom">{{this.semestres_aprobados}} Semestres</span>
                </div>
                {{#if this.numero_tarjeta_profesional}}
                <div class="col-auto">
                    <span class="badge-custom">T.P: {{this.numero_tarjeta_profesional}}</span>
                </div>
                {{/if}}
            </div>

            {{#if this.documento}}
            <div class="mt-2">
                <a href="/hoja/soporte/educacion/{{this.id_educacion_superior}}" target="_blank" class="download-link">
                    <i class="fas fa-paperclip me-1"></i> Ver Soporte
                </a>
            </div>
            {{/if}}
        </div>
        {{/each}}
        {{/if}}

        <!-- Idiomas -->
        {{#if idiomas.length}}
        <h5 class="mb-3 mt-4 text-secondary fw-bold small">IDIOMAS</h5>
        <div class="row g-3">
            {{#each idiomas}}
            <div class="col-md-4">
                <div class="card-custom p-3 mb-0">
                    <h6 class="fw-bold mb-2">{{this.idioma}}</h6>
                    <div class="d-flex justify-content-between small text-muted border-bottom pb-1 mb-1">
                        <span>Habla</span> <strong>{{this.lo_habla}}</strong>
                    </div>
                    <div class="d-flex justify-content-between small text-muted border-bottom pb-1 mb-1">
                        <span>Lee</span> <strong>{{this.lo_lee}}</strong>
                    </div>
                    <div class="d-flex justify-content-between small text-muted">
                        <span>Escribe</span> <strong>{{this.lo_escribe}}</strong>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
        {{/if}}

        <!-- 3. EXPERIENCIA LABORAL -->
        <h2 class="section-title"><i class="fas fa-briefcase me-2"></i> Experiencia Laboral</h2>

        {{#if empleoActual}}
        <div class="card-custom border-primary border-opacity-25 bg-white shadow-sm">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="badge bg-success mb-2">EMPLEO ACTUAL</span>
                    <h4 class="fw-bold mb-1">{{empleoActual.cargo_actual}}</h4>
                    <h5 class="text-primary mb-2">{{empleoActual.empresa_entidad}}</h5>
                </div>
                <div class="text-end">
                    <span class="badge bg-light text-dark border">{{empleoActual.tipo}}</span>
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-4">
                    <div class="info-label">Fecha Ingreso</div>
                    <div class="fw-bold">{{formatFullDate empleoActual.fecha_ingreso}}</div>
                </div>
                {{#if empleoActual.fecha_retiro}}
                <div class="col-md-4">
                    <div class="info-label">Fecha Retiro</div>
                    <div class="fw-bold">{{formatFullDate empleoActual.fecha_retiro}}</div>
                </div>
                {{/if}}
                <div class="col-md-4">
                    <div class="info-label">Ubicación</div>
                    <div>{{empleoActual.municipio}}, {{empleoActual.departamento}}</div>
                    <small class="text-muted">{{empleoActual.pais}}</small>
                </div>

                <div class="col-md-6">
                    <div class="info-label">Contacto Entidad</div>
                    <div><i class="fas fa-envelope me-1 text-muted"></i> {{empleoActual.correo_entidad}}</div>
                    <div><i class="fas fa-phone me-1 text-muted"></i> {{empleoActual.telefono_entidad}}</div>
                </div>
                <div class="col-md-6">
                    <div class="info-label">Dependencia</div>
                    <div>{{empleoActual.dependencia}}</div>
                </div>
                <div class="col-12">
                    <div class="info-label">Dirección</div>
                    <div>{{empleoActual.direccion}}</div>
                </div>
            </div>

            {{#if empleoActual.documento}}
            <div class="mt-3 pt-2 border-top">
                <a href="/hoja/soporte/experiencia/{{empleoActual.id_experiencia}}" target="_blank"
                    class="download-link">
                    <i class="fas fa-paperclip me-1"></i> Ver Certificado Laboral
                </a>
            </div>
            {{/if}}
        </div>
        {{/if}}

        <!-- Empleos Anteriores -->
        {{#if empleosAnteriores.length}}
        <h5 class="mb-3 mt-4 text-secondary fw-bold small">HISTORIAL LABORAL</h5>
        {{#each empleosAnteriores}}
        <div class="timeline-item">
            <div class="timeline-date">
                {{formatFullDate this.fecha_ingreso}} - {{#if this.fecha_retiro}}{{formatFullDate
                this.fecha_retiro}}{{else}}Presente{{/if}}
            </div>
            <div class="timeline-title">{{this.cargo_actual}}</div>
            <div class="timeline-subtitle">{{this.empresa_entidad}} <span
                    class="badge bg-light text-dark border ms-2">{{this.tipo}}</span></div>

            <div class="mb-2">
                <small class="text-muted"><i class="fas fa-map-marker-alt me-1"></i> {{this.municipio}},
                    {{this.departamento}}</small>
            </div>

            <button class="btn btn-sm btn-link p-0 text-decoration-none" type="button" data-bs-toggle="collapse"
                data-bs-target="#detallesEmpleo{{this.id_experiencia}}">
                Ver más detalles <i class="fas fa-chevron-down ms-1"></i>
            </button>

            <div class="collapse mt-2" id="detallesEmpleo{{this.id_experiencia}}">
                <div class="card card-body bg-light border-0 p-3 small">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <strong>Dependencia:</strong> {{this.dependencia}}
                        </div>
                        <div class="col-md-6">
                            <strong>Contacto:</strong> {{this.correo_entidad}}
                        </div>
                        <div class="col-12">
                            <strong>Dirección:</strong> {{this.direccion}}
                        </div>
                    </div>
                    {{#if this.documento}}
                    <div class="mt-2 pt-2 border-top">
                        <a href="/hoja/soporte/experiencia/{{this.id_experiencia}}" target="_blank"
                            class="download-link">
                            <i class="fas fa-paperclip me-1"></i> Ver Soporte
                        </a>
                    </div>
                    {{/if}}
                </div>
            </div>
        </div>
        {{/each}}
        {{/if}}

        <!-- 4. TIEMPO TOTAL -->
        <h2 class="section-title"><i class="fas fa-clock me-2"></i> Tiempo Total de Experiencia</h2>
        <div class="table-responsive">
            <table class="table table-bordered table-custom">
                <thead>
                    <tr>
                        <th>Ocupación</th>
                        <th class="text-center" style="width: 100px;">Años</th>
                        <th class="text-center" style="width: 100px;">Meses</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Servidor Público</td>
                        <td class="text-center">{{tiempo_experiencia.anios_servidor_publico}}</td>
                        <td class="text-center">{{tiempo_experiencia.meses_servidor_publico}}</td>
                    </tr>
                    <tr>
                        <td>Sector Privado</td>
                        <td class="text-center">{{tiempo_experiencia.anios_sector_privado}}</td>
                        <td class="text-center">{{tiempo_experiencia.meses_sector_privado}}</td>
                    </tr>
                    <tr>
                        <td>Trabajador Independiente</td>
                        <td class="text-center">{{tiempo_experiencia.anios_trabajador_independiente}}</td>
                        <td class="text-center">{{tiempo_experiencia.meses_trabajador_independiente}}</td>
                    </tr>
                    <tr class="table-light fw-bold">
                        <td>TOTAL</td>
                        <td class="text-center">{{tiempo_experiencia.anios_total_experiencia}}</td>
                        <td class="text-center">{{tiempo_experiencia.meses_total_experiencia}}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- 5. SOPORTES ADICIONALES -->
        {{#if documentos.length}}
        <h2 class="section-title"><i class="fas fa-folder-open me-2"></i> Soportes Adicionales</h2>
        <div class="row g-3">
            {{#each documentos}}
            <div class="col-md-6">
                <div class="card-custom p-3 d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-file-alt text-primary fs-4 me-3"></i>
                        <div class="text-truncate" style="max-width: 200px;" title="{{this.original_name}}">
                            {{this.original_name}}
                        </div>
                    </div>
                    <a href="/hoja/documento/{{this.id_documento}}" target="_blank"
                        class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-download"></i>
                    </a>
                </div>
            </div>
            {{/each}}
        </div>
        {{/if}}

    </div>
</div>

<!-- Floating Action Button for Mobile -->
<div class="fab-container d-md-none no-print">
    <a href="/hoja/generar-pdf/{{persona.unique_identifier}}" class="btn btn-primary rounded-circle shadow-lg p-3">
        <i class="fas fa-file-pdf fa-lg"></i>
    </a>
</div>