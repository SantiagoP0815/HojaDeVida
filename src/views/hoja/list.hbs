<style>
    body {
        /* Mismo fondo para consistencia */
        background: url('/img/paramoaire.jpg') no-repeat center center fixed !important;
        background-size: cover !important;
        overflow: hidden;
    }

    @media (max-width: 768px) {
        body {
            overflow: auto;
        }
    }

    .container-list {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        padding: 2rem;
        margin: 2rem auto;
        max-width: 1200px;
        height: 85vh; /* Altura fija para el contenedor */
        display: flex;
        flex-direction: column;
    }

    .list-header {
        margin-bottom: 2rem;
    }

    .list-content {
        flex: 1;
        overflow-y: auto; /* Scroll interno */
        padding-right: 10px;
    }

    /* Scrollbar personalizado */
    .list-content::-webkit-scrollbar {
        width: 8px;
    }
    .list-content::-webkit-scrollbar-track {
        background: #f1f1f1;
    }
    .list-content::-webkit-scrollbar-thumb {
        background: #888;
        border-radius: 4px;
    }
    .list-content::-webkit-scrollbar-thumb:hover {
        background: #555;
    }

    .user-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border: none;
        background: white;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .user-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .user-avatar {
        width: 50px;
        height: 50px;
        background-color: #3b4ce2;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-weight: bold;
        font-size: 1.2rem;
    }

    .admin-badge {
        font-size: 0.7rem;
        padding: 0.25rem 0.5rem;
    }

    .search-input {
        border-radius: 50px;
        padding-left: 1.5rem;
    }
    
    .btn-search {
        border-radius: 50px;
        padding-right: 1.5rem;
        padding-left: 1.5rem;
    }
</style>

<div class="container container-list">
    
    <!-- HEADER Y BÚSQUEDA -->
    <div class="list-header border-bottom pb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="fw-bold mb-0 text-primary"><i class="fas fa-users-cog me-2"></i> Gestión de Usuarios</h2>
                <p class="text-muted mb-0 small">Busque por nombre, documento, títulos universitarios o idiomas.</p>
            </div>
            
            <form action="/hoja/list" method="GET" class="d-flex flex-grow-1" style="max-width: 500px;">
                <div class="input-group">
                    <input type="text" name="search" class="form-control search-input" placeholder="Ej: Ingeniero, Inglés, Juan..." value="{{search}}">
                    <button class="btn btn-primary btn-search" type="submit">
                        <i class="fas fa-search"></i> Buscar
                    </button>
                    {{#if search}}
                        <a href="/hoja/list" class="btn btn-outline-secondary" title="Limpiar filtro">
                            <i class="fas fa-times"></i>
                        </a>
                    {{/if}}
                </div>
            </form>
        </div>
    </div>

    <!-- CONTENIDO DE LA LISTA -->
    <div class="list-content">
        {{#if personas.length}}
            <div class="row g-3">
                {{#each personas}}
                <div class="col-lg-4 col-md-6">
                    <div class="card user-card h-100">
                        <div class="card-body d-flex align-items-center">
                            <!-- Avatar con Icono (Solución al error split) -->
                            <div class="user-avatar me-3 flex-shrink-0">
                                <i class="fas fa-user"></i>
                            </div>
                            
                            <div class="flex-grow-1 overflow-hidden">
                                <h6 class="fw-bold mb-1 text-truncate" title="{{this.nombres}} {{this.primer_apellido}}">
                                    {{this.nombres}} {{this.primer_apellido}}
                                    {{#if (eq this.admin "SI")}}
                                        <span class="badge bg-warning text-dark admin-badge ms-1">ADMIN</span>
                                    {{/if}}
                                </h6>
                                <p class="mb-1 text-muted small text-truncate">
                                    <i class="far fa-id-card me-1"></i> {{this.numero_documento}}
                                </p>
                                <p class="mb-2 text-muted small text-truncate">
                                    <i class="far fa-envelope me-1"></i> {{this.email}}
                                </p>
                                
                                <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                                    <a href="/hoja/view/{{this.unique_identifier}}" class="btn btn-sm btn-outline-primary w-100" target="_blank">
                                        <i class="fas fa-eye me-1"></i> Ver Hoja
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        {{else}}
            <div class="text-center py-5">
                <div class="display-1 text-muted mb-3"><i class="fas fa-search"></i></div>
                <h4 class="text-muted">No se encontraron resultados</h4>
                <p class="text-muted">Intente con otra palabra clave como "Inglés", "Ingeniería" o el nombre de la persona.</p>
                <a href="/hoja/list" class="btn btn-primary mt-2">Ver todos los usuarios</a>
            </div>
        {{/if}}
    </div>
</div>