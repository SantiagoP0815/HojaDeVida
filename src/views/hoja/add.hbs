<style>
    body {
        /* Fondo fijo que cubre todo */
        background: url('/img/paramoaire.jpg') no-repeat center center fixed !important;
        background-size: cover !important;
        overflow: hidden;
    }

    @media (max-width: 768px) {
        body {
            overflow: auto;
        }
    }

    /* Limpiar contenedores padres */
    .container-main,
    main,
    .main-layout {
        background: transparent !important;
        box-shadow: none !important;
        padding: 0 !important;
        margin: 0 !important;
        height: 100%;
    }

    /* Estilo para el botón de eliminar flotante */
    .btn-delete-float {
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 10;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
    }

    /* Asegurar que el item dinámico tenga posición relativa para posicionar el botón */
    .dynamic-item {
        position: relative;
        padding-top: 2.5rem !important;
        /* Espacio extra arriba para que el botón no tape inputs */
    }
</style>

<div class="editor-layout">

    <aside class="editor-sidebar">
        <!-- FOTO DE PERFIL EN SIDEBAR -->
        <div class="text-center mb-4">
            <div class="position-relative d-inline-block">
                {{#if user.foto_perfil}}
                <img src="/docs/{{user.foto_perfil}}" alt="Foto de Perfil" class="rounded-circle shadow-sm"
                    style="width: 100px; height: 100px; object-fit: cover; border: 3px solid #fff;">
                {{else}}
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center shadow-sm mx-auto"
                    style="width: 100px; height: 100px; border: 3px solid #fff;">
                    <i class="fas fa-user fa-3x text-secondary"></i>
                </div>
                {{/if}}
            </div>
            <h6 class="mt-2 fw-bold text-dark">{{user.nombres}}</h6>
        </div>

        <h5 class="mb-4 text-secondary ps-2 d-none d-md-block fw-bold" style="font-size: 0.9rem; letter-spacing: 1px;">
            NAVEGACIÓN</h5>

        <button type="button" id="nav-btn-datos" class="menu-btn active" onclick="mostrarSeccion('datos')">
            <i class="fas fa-id-card"></i>
            <span>Datos Personales</span>
        </button>
        <button type="button" id="nav-btn-formacion" class="menu-btn" onclick="mostrarSeccion('formacion')">
            <i class="fas fa-graduation-cap"></i>
            <span>Formación</span>
        </button>
        <button type="button" id="nav-btn-experiencia" class="menu-btn" onclick="mostrarSeccion('experiencia')">
            <i class="fas fa-briefcase"></i>
            <span>Experiencia</span>
        </button>
        <button type="button" id="nav-btn-tiempo" class="menu-btn" onclick="mostrarSeccion('tiempo')">
            <i class="fas fa-clock"></i>
            <span>Tiempo Total</span>
        </button>
        <button type="button" id="nav-btn-documentos" class="menu-btn" onclick="mostrarSeccion('documentos')">
            <i class="fas fa-folder-open"></i>
            <span>Soportes</span>
        </button>

        <div class="sidebar-actions mt-auto pt-4 border-top d-none d-md-block">
            <button type="button" id="btnGuardarDesktop" class="btn btn-success w-100 mb-2 shadow-sm"
                onclick="enviarFormulario()">
                <i class="fas fa-save me-2"></i> GUARDAR CAMBIOS
            </button>
            <button type="button" class="btn btn-primary w-100 mb-2 shadow-sm" onclick="descargarPDF()">
                <i class="fas fa-file-pdf me-2"></i> DESCARGAR PDF
            </button>
            <!-- NUEVO BOTÓN PARA PERFIL PÚBLICO -->
            <a href="/hoja/view/{{user.unique_identifier}}" target="_blank"
                class="btn btn-outline-dark w-100 shadow-sm">
                <i class="fas fa-external-link-alt me-2"></i> VER PERFIL PÚBLICO
            </a>
        </div>
    </aside>

    <div class="editor-content">
        <form id="hojaForm" action="/hoja/insertar-datos?_csrf={{csrfToken}}" method="POST"
            enctype="multipart/form-data">

            <input type="hidden" name="_csrf" value="{{csrfToken}}">

            <!-- SECCIÓN 1: DATOS PERSONALES -->
            <div id="sec-datos" class="seccion-tab active">
                <div class="form-card">
                    <h2 class="section-title">1. DATOS PERSONALES</h2>
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="foto_perfil" class="form-label fw-bold">Foto de Perfil</label>
                            <input type="file" class="form-control" id="foto_perfil" name="foto_perfil"
                                accept="image/*">
                            <div class="form-text">Sube una foto profesional (JPG, PNG).</div>
                        </div>
                    </div>
                    <div class="row g-3 mt-2">
                        <div class="col-md-6"><label class="form-label">Primer Apellido</label><input type="text"
                                class="form-control" name="primer_apellido" value="{{user.primer_apellido}}" required>
                        </div>
                        <div class="col-md-6"><label class="form-label">Segundo Apellido</label><input type="text"
                                class="form-control" name="segundo_apellido" value="{{user.segundo_apellido}}"></div>
                        <div class="col-12"><label class="form-label">Nombres</label><input type="text"
                                class="form-control" name="nombres" value="{{user.nombres}}" required></div>
                    </div>
                    <hr class="my-4">
                    <h6 class="fw-bold text-muted mb-3">DOCUMENTO DE IDENTIFICACIÓN</h6>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Tipo</label>
                            <select class="form-select" name="tipo_documento" required>
                                <option value="C.C" {{#if (eq user.tipo_documento "C.C" )}}selected{{/if}}>C.C</option>
                                <option value="C.E" {{#if (eq user.tipo_documento "C.E" )}}selected{{/if}}>C.E</option>
                                <option value="PAS" {{#if (eq user.tipo_documento "PAS" )}}selected{{/if}}>PAS</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Número</label>
                            <input type="text" class="form-control" name="numero_documento"
                                value="{{user.numero_documento}}" required>
                        </div>

                        <div class="col-md-5">
                            <label class="form-label">Sexo</label>
                            <div class="d-flex gap-2 mt-1">
                                <input type="radio" class="btn-check" name="sexo" id="sexoM" value="M" {{#if (eq
                                    user.sexo "M" )}}checked{{/if}}>
                                <label class="btn btn-outline-primary flex-fill" for="sexoM"><i class="fas fa-male"></i>
                                    Masculino</label>

                                <input type="radio" class="btn-check" name="sexo" id="sexoF" value="F" {{#if (eq
                                    user.sexo "F" )}}checked{{/if}}>
                                <label class="btn btn-outline-primary flex-fill" for="sexoF"><i
                                        class="fas fa-female"></i> Femenino</label>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <label class="form-label">Nacionalidad</label>
                            <div class="d-flex gap-2 mt-1">
                                <input type="radio" class="btn-check" name="nacionalidad" id="nacCol" value="COLOMBIANO"
                                    {{#if (eq user.nacionalidad "COLOMBIANO" )}}checked{{/if}}
                                    onchange="togglePais(this)">
                                <label class="btn btn-outline-secondary flex-fill" for="nacCol">Colombiano</label>

                                <input type="radio" class="btn-check" name="nacionalidad" id="nacExt" value="EXTRANJERO"
                                    {{#if (eq user.nacionalidad "EXTRANJERO" )}}checked{{/if}}
                                    onchange="togglePais(this)">
                                <label class="btn btn-outline-secondary flex-fill" for="nacExt">Extranjero</label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">País</label>
                            <input type="text" class="form-control" id="inputPais" name="pais" value="{{user.pais}}">
                        </div>
                    </div>
                    <hr class="my-4">
                    <h6 class="fw-bold text-muted mb-3">LIBRETA MILITAR</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Clase</label>
                            <select class="form-select" name="tipo_libreta_militar">
                                <option value="">Seleccione...</option>
                                <option value="PRIMERA CLASE" {{#if (eq user.tipo_libreta_militar "PRIMERA CLASE"
                                    )}}selected{{/if}}>Primera Clase</option>
                                <option value="SEGUNDA CLASE" {{#if (eq user.tipo_libreta_militar "SEGUNDA CLASE"
                                    )}}selected{{/if}}>Segunda Clase</option>
                            </select>
                        </div>
                        <div class="col-md-4"><label class="form-label">Número</label><input type="text"
                                class="form-control" name="numero_libreta_militar"
                                value="{{user.numero_libreta_militar}}"></div>
                        <div class="col-md-4"><label class="form-label">D.M</label><input type="text"
                                class="form-control" name="dm_libreta_militar" value="{{user.dm_libreta_militar}}">
                        </div>
                    </div>
                    <hr class="my-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <h6 class="fw-bold text-muted">FECHA Y LUGAR DE NACIMIENTO</h6>
                        </div>
                        <div class="col-md-3"><label class="form-label">Fecha</label><input type="date"
                                class="form-control" name="fecha_nacimiento" value="{{user.fecha_nacimiento}}"></div>
                        <div class="col-md-3"><label class="form-label">País</label><input type="text"
                                class="form-control" name="pais_nacimiento" value="{{user.pais_nacimiento}}"></div>
                        <div class="col-md-3"><label class="form-label">Depto</label><input type="text"
                                class="form-control" name="departamento_nacimiento"
                                value="{{user.departamento_nacimiento}}"></div>
                        <div class="col-md-3"><label class="form-label">Municipio</label><input type="text"
                                class="form-control" name="municipio_nacimiento" value="{{user.municipio_nacimiento}}">
                        </div>
                    </div>
                    <div class="row g-3 mt-3">
                        <div class="col-12">
                            <h6 class="fw-bold text-muted">DATOS DE CONTACTO</h6>
                        </div>
                        <div class="col-12"><label class="form-label">Dirección</label><input type="text"
                                class="form-control" name="direccion_correspondencia"
                                value="{{user.direccion_correspondencia}}"></div>
                        <div class="col-md-4"><label class="form-label">País</label><input type="text"
                                class="form-control" name="pais_correspondencia" value="{{user.pais_correspondencia}}">
                        </div>
                        <div class="col-md-4"><label class="form-label">Depto</label><input type="text"
                                class="form-control" name="departamento_correspondencia"
                                value="{{user.departamento_correspondencia}}"></div>
                        <div class="col-md-4"><label class="form-label">Municipio</label><input type="text"
                                class="form-control" name="municipio_correspondencia"
                                value="{{user.municipio_correspondencia}}"></div>
                        <div class="col-md-6"><label class="form-label">Teléfono</label><input type="tel"
                                class="form-control" name="telefono" value="{{user.telefono}}"></div>
                        <div class="col-md-6"><label class="form-label">Email</label><input type="email"
                                class="form-control" name="email" value="{{user.email}}"></div>
                    </div>
                    <!-- BOTONES DE NAVEGACIÓN -->
                    <div class="d-flex justify-content-end mt-3">
                        <button type="button" class="btn btn-primary shadow-sm px-4"
                            onclick="mostrarSeccion('formacion')">
                            Siguiente <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- SECCIÓN 2: FORMACIÓN ACADÉMICA -->
            <div id="sec-formacion" class="seccion-tab">
                <div class="form-card">
                    <h2 class="section-title">2. FORMACIÓN ACADÉMICA</h2>
                    <div class="p-3 mb-4 rounded border bg-white">
                        <h6 class="fw-bold">EDUCACIÓN BÁSICA Y MEDIA</h6>
                        <p class="small text-muted mb-2">Marque el último grado aprobado:</p>
                        <div class="d-flex flex-wrap gap-2 mb-3 justify-content-center justify-content-md-start">
                            {{#each (range 1 12)}}
                            <div class="flex-grow-0">
                                <input type="radio" class="btn-check" name="educacion_basica" id="grado_{{this}}"
                                    value="{{this}}" {{#if (eq ../educacion_basica_media.educacion_basica (add ""
                                    this))}}checked{{/if}}>
                                <label class="btn btn-outline-primary fw-bold" for="grado_{{this}}"
                                    style="width: 50px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                    {{this}}°
                                </label>
                            </div>
                            {{/each}}
                        </div>
                        <div class="row g-3">
                            <div class="col-md-8"><label class="form-label">Título Obtenido</label><input type="text"
                                    class="form-control" name="titulo_obtenido"
                                    value="{{educacion_basica_media.titulo_obtenido}}"></div>
                            <div class="col-md-4"><label class="form-label">Fecha Grado</label><input type="month"
                                    class="form-control" name="fecha_grado"
                                    value="{{educacion_basica_media.fecha_grado}}"></div>
                        </div>
                    </div>
                    <h6 class="fw-bold mt-4 mb-3">EDUCACIÓN SUPERIOR</h6>
                    <div id="container-estudios">
                        {{#if educacion_superior.length}}
                        {{#each educacion_superior}}
                        {{> estudioItem index=@index data=this}}
                        {{/each}}
                        {{else}}
                        {{> estudioItem index=0}}
                        {{/if}}
                    </div>
                    <button type="button" class="btn btn-outline-success btn-sm"
                        onclick="agregarBloque('container-estudios', 'estudio-item')"><i class="fas fa-plus"></i>
                        Agregar Estudio</button>
                    <hr class="my-4">
                    <h6 class="fw-bold mb-3">IDIOMAS</h6>
                    <div id="container-idiomas">
                        {{#if idiomas.length}}
                        {{#each idiomas}}
                        {{> idiomaItem index=@index data=this}}
                        {{/each}}
                        {{else}}
                        {{> idiomaItem index=0}}
                        {{/if}}
                    </div>
                    <button type="button" class="btn btn-outline-success btn-sm"
                        onclick="agregarBloque('container-idiomas', 'idioma-item')"><i class="fas fa-plus"></i>
                        Agregar
                        Idioma</button>
                    <!-- BOTONES DE NAVEGACIÓN -->
                    <div class="d-flex justify-content-between mt-3">
                        <button type="button" class="btn btn-secondary shadow-sm px-4"
                            onclick="mostrarSeccion('datos')">
                            <i class="fas fa-arrow-left me-2"></i> Anterior
                        </button>
                        <button type="button" class="btn btn-primary shadow-sm px-4"
                            onclick="mostrarSeccion('experiencia')">
                            Siguiente <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- SECCIÓN 3: EXPERIENCIA LABORAL -->
            <div id="sec-experiencia" class="seccion-tab">
                <div class="form-card">
                    <h2 class="section-title">3. EXPERIENCIA LABORAL</h2>
                    <h6 class="text-primary fw-bold mt-2">EMPLEO ACTUAL</h6>
                    <div class="border border-primary border-opacity-50 rounded p-3 mb-4 bg-white">
                        <input type="hidden" name="id_experiencia_0" value="{{empleoActual.id_experiencia}}">
                        <input type="hidden" name="empleo_actual_0" value="SI">

                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label fw-bold">Empresa / Entidad</label>
                                <input type="text" class="form-control" name="empresa_entidad_0"
                                    value="{{empleoActual.empresa_entidad}}">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Tipo</label>
                                <div class="d-flex gap-2 mt-1">
                                    <input type="radio" class="btn-check" name="tipo_0" id="tipo_priv_0" value="PRIVADA"
                                        {{#if (eq empleoActual.tipo "PRIVADA" )}}checked{{/if}}>
                                    <label class="btn btn-outline-secondary btn-sm flex-fill"
                                        for="tipo_priv_0">Privada</label>

                                    <input type="radio" class="btn-check" name="tipo_0" id="tipo_pub_0" value="PUBLICA"
                                        {{#if (eq empleoActual.tipo "PUBLICA" )}}checked{{/if}}>
                                    <label class="btn btn-outline-success btn-sm flex-fill"
                                        for="tipo_pub_0">Pública</label>
                                </div>
                            </div>

                            <div class="col-md-4"><label class="form-label">País</label><input type="text"
                                    class="form-control" name="pais_0" value="{{empleoActual.pais}}"></div>
                            <div class="col-md-4"><label class="form-label">Depto</label><input type="text"
                                    class="form-control" name="departamento_0" value="{{empleoActual.departamento}}">
                            </div>
                            <div class="col-md-4"><label class="form-label">Municipio</label><input type="text"
                                    class="form-control" name="municipio_0" value="{{empleoActual.municipio}}">
                            </div>
                            <div class="col-md-6"><label class="form-label">Correo</label><input type="email"
                                    class="form-control" name="correo_entidad_0"
                                    value="{{empleoActual.correo_entidad}}">
                            </div>
                            <div class="col-md-6"><label class="form-label">Teléfonos</label><input type="text"
                                    class="form-control" name="telefono_entidad_0"
                                    value="{{empleoActual.telefono_entidad}}">
                            </div>
                            <div class="col-md-6"><label class="form-label">Ingreso</label><input type="date"
                                    class="form-control" name="fecha_ingreso_0" value="{{empleoActual.fecha_ingreso}}">
                            </div>
                            <div class="col-md-6"><label class="form-label">Retiro</label><input type="date"
                                    class="form-control" name="fecha_retiro_0" value="{{empleoActual.fecha_retiro}}">
                            </div>
                            <div class="col-md-6"><label class="form-label">Cargo</label><input type="text"
                                    class="form-control" name="cargo_actual_0" value="{{empleoActual.cargo_actual}}">
                            </div>
                            <div class="col-md-6"><label class="form-label">Dependencia</label><input type="text"
                                    class="form-control" name="dependencia_0" value="{{empleoActual.dependencia}}">
                            </div>
                            <div class="col-12"><label class="form-label">Dirección</label><input type="text"
                                    class="form-control" name="direccion_0" value="{{empleoActual.direccion}}">
                            </div>
                            <div class="col-12"><label class="form-label text-primary">Soporte</label><input type="file"
                                    class="form-control" name="documento_experiencia_0"></div>
                        </div>
                    </div>

                    <h6 class="fw-bold text-muted">EMPLEOS ANTERIORES</h6>
                    <div id="container-empleos">
                        {{#if empleosAnteriores.length}}
                        {{#each empleosAnteriores}}
                        {{> empleoItem index=(add @index 1) data=this}}
                        {{/each}}
                        {{else}}
                        {{> empleoItem index=1}}
                        {{/if}}
                    </div>
                    <button type="button" class="btn btn-outline-success btn-sm"
                        onclick="agregarBloque('container-empleos', 'empleo-item')"><i class="fas fa-plus"></i>
                        Agregar
                        Empleo
                    </button>
                    <!-- BOTONES DE NAVEGACIÓN -->
                    <div class="d-flex justify-content-between mt-3">
                        <button type="button" class="btn btn-secondary shadow-sm px-4"
                            onclick="mostrarSeccion('formacion')">
                            <i class="fas fa-arrow-left me-2"></i> Anterior
                        </button>
                        <button type="button" class="btn btn-primary shadow-sm px-4" onclick="mostrarSeccion('tiempo')">
                            Siguiente <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- SECCIÓN 4: TIEMPO TOTAL -->
            <div id="sec-tiempo" class="seccion-tab">
                <div class="form-card">
                    <h2 class="section-title">4. TIEMPO TOTAL</h2>
                    <div class="table-responsive">
                        <table class="table table-bordered bg-white">
                            <thead class="table-light">
                                <tr>
                                    <th>OCUPACIÓN</th>
                                    <th style="width:100px">AÑOS</th>
                                    <th style="width:100px">MESES</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>SERVIDOR PÚBLICO</td>
                                    <td><input type="number" class="form-control" name="anios_servidor_publico"
                                            value="{{tiempo_experiencia.anios_servidor_publico}}"></td>
                                    <td><input type="number" class="form-control" name="meses_servidor_publico"
                                            value="{{tiempo_experiencia.meses_servidor_publico}}"></td>
                                </tr>
                                <tr>
                                    <td>SECTOR PRIVADO</td>
                                    <td><input type="number" class="form-control" name="anios_sector_privado"
                                            value="{{tiempo_experiencia.anios_sector_privado}}"></td>
                                    <td><input type="number" class="form-control" name="meses_sector_privado"
                                            value="{{tiempo_experiencia.meses_sector_privado}}"></td>
                                </tr>
                                <tr>
                                    <td>INDEPENDIENTE</td>
                                    <td><input type="number" class="form-control" name="anios_trabajador_independiente"
                                            value="{{tiempo_experiencia.anios_trabajador_independiente}}"></td>
                                    <td><input type="number" class="form-control" name="meses_trabajador_independiente"
                                            value="{{tiempo_experiencia.meses_trabajador_independiente}}"></td>
                                </tr>
                                <tr class="fw-bold table-secondary">
                                    <td>TOTAL</td>
                                    <td><input type="number" class="form-control" name="anios_total_experiencia"
                                            value="{{tiempo_experiencia.anios_total_experiencia}}" readonly>
                                    </td>
                                    <td><input type="number" class="form-control" name="meses_total_experiencia"
                                            value="{{tiempo_experiencia.meses_total_experiencia}}" readonly>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <!-- BOTONES DE NAVEGACIÓN -->
                    <div class="d-flex justify-content-between mt-3">
                        <button type="button" class="btn btn-secondary shadow-sm px-4"
                            onclick="mostrarSeccion('experiencia')">
                            <i class="fas fa-arrow-left me-2"></i> Anterior
                        </button>
                        <button type="button" class="btn btn-primary shadow-sm px-4"
                            onclick="mostrarSeccion('documentos')">
                            Siguiente <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- SECCIÓN 5: SOPORTES -->
            <div id="sec-documentos" class="seccion-tab">
                <div class="form-card">
                    <h2 class="section-title">SOPORTES</h2>
                    <div class="mb-4">
                        <label class="form-label">Documento de Identidad (Si falta)</label>
                        <input type="file" name="documento_id" class="form-control">
                    </div>
                    <h6 class="fw-bold">Archivos Cargados</h6>
                    <ul class="list-group mt-2">
