                            onclick="mostrarSeccion('tiempo')">
                            <i class="fas fa-arrow-left me-2"></i> Anterior
                        </button>
                    </div>
                </div>
            </div>

            <div class="d-md-none mobile-fab">
                <button type="button" id="btnGuardarMovil" class="btn btn-success shadow rounded-pill"
                    onclick="enviarFormulario()"><i class="fas fa-save"></i> Guardar</button>
                <button type="button" class="btn btn-primary shadow rounded-pill" onclick="descargarPDF()"><i
                        class="fas fa-file-pdf"></i> PDF</button>
