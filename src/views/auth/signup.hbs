<style>
  body {
    background: url('/img/paramoaire.jpg') no-repeat center center fixed !important;
    background-size: cover !important;
  }

  .container-main,
  main {
    background: transparent !important;
    box-shadow: none !important;
    padding: 0 !important;
  }
</style>

<main class="d-flex align-items-center justify-content-center" style="min-height: 90vh; padding: 20px 0;">
  <div class="card auth-card shadow-lg border-0"
    style="max-width: 700px; width: 100%; background: rgba(255, 255, 255, 0.95);">
    <div class="card-body p-5">
      <div class="auth-header text-center mb-4">
        <h3 class="fw-bold text-primary">Crear Cuenta</h3>
        <p class="text-muted">Únete a nuestra comunidad</p>
      </div>
      <form action="/signup" method="POST" novalidate>
        <input type="hidden" name="_csrf" value="{{csrfToken}}">

        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label text-muted small fw-bold">PRIMER APELLIDO</label>
            <input type="text" name="primer_apellido" class="form-control" placeholder="Apellido paterno" required>
          </div>
          <div class="col-md-6">
            <label class="form-label text-muted small fw-bold">SEGUNDO APELLIDO</label>
            <input type="text" name="segundo_apellido" class="form-control" placeholder="Apellido materno" required>
          </div>

          <div class="col-12">
            <label class="form-label text-muted small fw-bold">NOMBRES</label>
            <input type="text" name="nombres" class="form-control" placeholder="Nombres completos" required>
          </div>

          <div class="col-md-6">
            <label class="form-label text-muted small fw-bold">TIPO DOCUMENTO</label>
            <select name="tipo_documento" class="form-select" required>
              <option value="">Seleccione...</option>
              <option value="C.C">Cédula de Ciudadanía</option>
              <option value="C.E">Cédula de Extranjería</option>
              <option value="PAS">Pasaporte</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label text-muted small fw-bold">NÚMERO DOCUMENTO</label>
            <input type="text" name="numero_documento" class="form-control" placeholder="Ej: 123456789" required>
          </div>

          <div class="col-12">
            <label class="form-label text-muted small fw-bold">CONTRASEÑA</label>
            <input type="password" name="password" class="form-control" placeholder="Mínimo 6 caracteres" required>
          </div>

          <div class="col-12">
            <label class="form-label text-muted small fw-bold">VEREDA</label>
            <select name="vereda" class="form-select" required>
              <option value="">Seleccione su vereda...</option>
              <option value="Pedregal Alto">Pedregal Alto</option>
              <option value="Pedregal Bajo">Pedregal Bajo</option>
              <option value="La Lajita">La Lajita</option>
              <option value="El Bosque">El Bosque</option>
              <option value="El Moral">El Moral</option>
              <option value="El Palmar">El Palmar</option>
              <option value="Palmarito">Palmarito</option>
              <option value="Juan Curí">Juan Curí</option>
              <option value="La Laguna">La Laguna</option>
              <option value="Santa Rita">Santa Rita</option>
              <option value="Caguanoque">Caguanoque</option>
              <option value="Centro">Centro</option>
            </select>
          </div>

          <div class="col-12">
            <label class="form-label text-muted small fw-bold">PREGUNTA DE SEGURIDAD</label>
            <p class="small text-muted mb-2">¿Cómo se llama el presidente de la junta de acción comunal de tu vereda?
            </p>
            <input type="text" name="respuesta_junta" class="form-control" placeholder="Respuesta" required>
          </div>
        </div>

        <div class="d-grid gap-2 mt-4">
          <button class="btn btn-primary btn-lg fw-bold" type="submit">
            REGISTRARSE
          </button>
        </div>
        <p class="text-center text-muted mt-3 mb-0">¿Ya tienes cuenta? <a href="/signin"
            class="text-primary fw-bold text-decoration-none">Inicia sesión</a></p>
      </form>
    </div>
  </div>
</main>