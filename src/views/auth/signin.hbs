<style>
  body {
    background: url('/img/paramoaire.jpg') no-repeat center center fixed !important;
    background-size: cover !important;
  }

  .container-main,
  main {
    background: transparent !important;
    box-shadow: none !important;
    padding: 0 !important;
  }
</style>

<main class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">
  <div class="card auth-card shadow-lg border-0"
    style="max-width: 400px; width: 100%; background: rgba(255, 255, 255, 0.95);">
    <div class="card-body p-5">
      <div class="auth-header text-center mb-4">
        <h3 class="fw-bold text-primary">Bienvenido</h3>
        <p class="text-muted">Inicia sesión para continuar</p>
      </div>
      <form action="/signin" method="POST" novalidate>
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="mb-4">
          <label class="form-label text-muted small fw-bold">NÚMERO DE DOCUMENTO</label>
          <input type="text" name="numero_documento" class="form-control form-control-lg" placeholder="Ej: 123456789"
            autofocus required>
        </div>
        <div class="mb-4">
          <label class="form-label text-muted small fw-bold">CONTRASEÑA</label>
          <input type="password" name="password" class="form-control form-control-lg" placeholder="********" required>
        </div>
        <div class="d-grid gap-2 mb-4">
          <button class="btn btn-primary btn-lg fw-bold" type="submit">
            INICIAR SESIÓN
          </button>
        </div>
        <p class="text-center text-muted mb-0">¿No tienes una cuenta? <a href="/signup"
            class="text-primary fw-bold text-decoration-none">Regístrate aquí</a></p>
      </form>
    </div>
  </div>
</main>